# Jekyll / Ruby build
.bundle/
.jekyll-cache/
.jekyll-metadata
.sass-cache/
_site/
# vendor/ = bundle install --path vendor
vendor/

# Node / Pagefind tooling (commit package.json + lockfile, not the deps)
node_modules/
.pagefind-cache/

# Editor / tooling local state
.obsidian
.ruby-lsp
.vscode/
.idea/

# Scratch — local braindumps & working files (not part of the site)
tmp/

# Ignore OS generated files #
.DS_Store*
ehthumbs.db
Thumbs.db

# Ignore packages #
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Always-ignore these #
*.diff
*.err
*.log
*.orig
*.rej
*.swn
*.swo
*.swp
._*
*~
